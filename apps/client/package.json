{
  "name": "frontend",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "scripts": {
    "--------------------------------<      DEV       >--------------------------------": "",
    "dev": "vite --config build/vite.config.web.ts",
    "--------------------------------<      BUILD     >--------------------------------": "",
    "build": "vite build --config build/vite.config.web.ts",
    "preview": "vite preview --config build/vite.config.web.ts",
    "--------------------------------< LINT & FORMAT >---------------------------------": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "--------------------------------<     UTILS     >---------------------------------": "",
    "icons:bundle": "bun run build/bundle-icons.ts"
  },
  "dependencies": {
    "@iconify-icons/mdi": "^1.2.48",
    "@vueuse/core": "^14.3.0",
    "reka-ui": "^2.10.0",
    "vue": "beta"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@iconify/utils": "^3.1.3",
    "@iconify/vue": "^5.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "2.0.1",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.0",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "@vue/compat": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "vue": "beta"
  }
}
