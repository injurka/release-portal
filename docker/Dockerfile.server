FROM oven/bun:1.2-slim

RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json bun.lock* ./
COPY apps/server/package.json ./apps/server/

RUN bun install

COPY . .

WORKDIR /app/apps/server

ENV PORT=4446
ENV NODE_ENV=production

EXPOSE 4446

CMD ["bun", "run", "start"]
