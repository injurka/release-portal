{
  "name": "@injurka/release-portal-server",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "--------------------------------<      DEV       >--------------------------------": "",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "users": "bun src/cli.ts",
    "--------------------------------<   DATABASE    >---------------------------------": "",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio",
    "db:reset": "bunx drizzle-kit drop",
    "db:seed": "bun src/scripts/seed-mock-data.ts",
    "--------------------------------< BACKUP & DUMP >---------------------------------": "",
    "dump:create": "bun src/scripts/create-dump.ts",
    "dump:seed": "bun src/scripts/seed-from-dump.ts",
    "deck:generate": "bun src/scripts/generate-deck.ts",
    "deck:seed": "bun src/scripts/seed-catalog.ts",
    "--------------------------------< LINT & FORMAT >---------------------------------": "",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "8.2.0",
    "@libsql/client": "^0.17.3",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.29.0",
    "eslint-plugin-format": "2.0.1",
    "typescript": "6.0.3"
  }
}
